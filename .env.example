# Environment Variables
# Copy this file to .env.local and fill in the values

# Database (Neon PostgreSQL - serverless)
# Dapatkan connection string dari https://app.neon.tech
# DATABASE_URL: connection string dengan PgBouncer untuk serverless
# DIRECT_URL: connection string langsung (tanpa PgBouncer) untuk migrations
DATABASE_URL="postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/dbname?pgbouncer=true&connection_limit=1&pool_timeout=0"
DIRECT_URL="postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/dbname"

# Authentication
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="https://your-netlify-app.netlify.app"

# Untuk development local
# NEXT_PUBLIC_API_URL=http://localhost:3000/api
