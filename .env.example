# Environment Variables
# Copy this file to .env.local and fill in the values

# Database (Neon PostgreSQL - serverless)
# Dapatkan connection string dari https://app.neon.tech
# Pake @prisma/adapter-neon — gak perlu PgBouncer
# DATABASE_URL: direct endpoint (tanpa -pooler)
# DIRECT_URL: sama aja
DATABASE_URL="postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/dbname?sslmode=require"
DIRECT_URL="postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/dbname?sslmode=require"

# Authentication
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="https://your-netlify-app.netlify.app"

# Untuk development local
# NEXT_PUBLIC_API_URL=http://localhost:3000/api
